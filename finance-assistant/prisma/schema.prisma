generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id // matches Supabase auth.users.id (UUID)
  email     String   @unique
  createdAt DateTime @default(now())

  transactions      Transaction[]
  budgets           Budget[]
  receipts          Receipt[]
  conversations     Conversation[]
  memories          UserMemory[]
  subscriptions     Subscription[]
  monthlyAggregates MonthlyAggregate[]

  @@map("users")
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  amount      Float
  type        String   @default("debit")
  merchant    String
  category    String   @default("uncategorized")
  rawMerchant String
  description String?
  source      String   @default("csv")
  importHash  String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, importHash])
  @@index([userId, date])
  @@index([userId, category, date])
  @@index([userId, merchant])
  @@map("transactions")
}

model MonthlyAggregate {
  id         String   @id @default(cuid())
  userId     String
  year       Int
  month      Int
  category   String
  totalSpent Float
  txCount    Int
  avgTx      Float
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month, category])
  @@index([userId, year, month])
  @@map("monthly_aggregates")
}

model Budget {
  id        String   @id @default(cuid())
  userId    String
  category  String
  limitAmt  Float
  period    String   @default("monthly")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, period])
  @@map("budgets")
}

model Receipt {
  id            String    @id @default(cuid())
  userId        String
  storagePath   String
  status        String    @default("pending")
  confidence    Float?
  extractedAt   DateTime?
  transactionId String?   @unique
  rawExtraction Json?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("receipts")
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  toolCalls      Json?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model UserMemory {
  id        String   @id @default(cuid())
  userId    String
  type      String
  key       String?
  value     String?
  rawFact   String
  tags      String[]
  status    String   @default("active")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, type])
  @@map("user_memories")
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String
  merchant        String
  normalizedName  String
  estimatedAmount Float
  frequency       String
  lastCharged     DateTime
  nextExpected    DateTime?
  confidence      Float
  isConfirmed     Boolean   @default(false)
  isCancelled     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@map("subscriptions")
}

model MerchantLookupCache {
  id          String   @id @default(cuid())
  merchantRaw String   @unique
  description String
  category    String
  website     String?
  source      String   @default("llm_inference")
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@map("merchant_lookup_cache")
}
